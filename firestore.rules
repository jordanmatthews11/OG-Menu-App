rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write only to signed-in users. App-level "authorized users"
    // are enforced in the app via the authorizedUsers collection.
    match /categories/{docId} {
      allow read, write: if request.auth != null;
    }
    match /storeLists/{docId} {
      allow read, write: if request.auth != null;
    }
    match /boosters/{docId} {
      allow read, write: if request.auth != null;
    }
    match /holdingCompanies/{docId} {
      allow read, write: if request.auth != null;
    }
    match /customCategoryCodes/{docId} {
      allow read, write: if request.auth != null;
    }
    match /authorizedUsers/{docId} {
      allow read, write: if request.auth != null;
    }
    match /feedback/{docId} {
      allow read, write: if request.auth != null;
    }
    match /legacyCodes/{docId} {
      allow read, write: if request.auth != null;
    }
    match /orders/{docId} {
      allow read, write: if request.auth != null;
    }
    match /support/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
